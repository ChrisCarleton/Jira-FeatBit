{
  "name": "featbit-jira",
  "version": "1.0.0",
  "description": "FeatBit integration for Jira",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "src/api",
    "src/ui"
  ],
  "scripts": {
    "build": "lerna run build",
    "build:typecheck": "lerna run build:typecheck",
    "build:watch": "lerna run build:watch --parallel",
    "deploy": "forge deploy",
    "format": "lerna run format",
    "format:check": "lerna run format:check",
    "lint": "lerna run lint",
    "lint:fix": "lerna run lint:fix",
    "test": "lerna run test",
    "test:coverage": "lerna run test:coverage --stream",
    "tunnel": "forge tunnel",
    "init-featbit": "node scripts/init-featbit.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.3.0",
    "lerna": "^8.0.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
